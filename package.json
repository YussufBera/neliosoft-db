{
  "name": "@neliosoft/db",
  "version": "0.1.0",
  "description": "Shared Prisma schema and client for Neliosoft platform and partner sites",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist",
    "prisma",
    "src"
  ],
  "scripts": {
    "build": "prisma generate && tsc",
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed-tenants.ts",
    "db:migrate-legacy": "node --env-file=.env --import tsx scripts/migrate-legacy.ts",
    "db:migrate-legacy:dry": "node --env-file=.env --import tsx scripts/migrate-legacy.ts --dry",
    "_postinstall_disabled": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
